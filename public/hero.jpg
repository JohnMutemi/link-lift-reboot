    <script>
      document.addEventListener('DOMContentLoaded', function () {
        // Get the navbar element
        var navbar = document.getElementById('myNavbar')
      
        // Function to apply styles on scroll
        function applyFirstStylesOnScroll() {
          // Check if the navbar has both sticky-top and shadow-sm classes
          if (navbar && navbar.classList.contains('sticky-top') && navbar.classList.contains('shadow-sm')) {
            // Check the scroll position
            var scrollPosition = window.scrollY || document.documentElement.scrollTop
      
            // Add the style margin-top: 0 !important; if scrolled
            if (scrollPosition > 0) {
              navbar.style.setProperty('margin-top', '0', 'important')
              // console.log(navbar.style.marginTop);
            } else if (scrollPosition <= 5) {
              // Adjust the threshold value as needed
              console.log('at-top')
              // Reset the style if at the top
              navbar.style.marginTop = ''
            }
          }
        }
      
        // Initial check
        applyFirstStylesOnScroll()
      
        // Attach the function to the scroll event
        window.addEventListener('scroll', applyFirstStylesOnScroll)
      })
    </script>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        // Get the navbar element
        var navbar = document.getElementById('myNavbar')
      
        // Function to apply styles on scroll
        function applySecondStylesOnScroll() {
          // Check if the navbar has both sticky-top and shadow-sm classes
          if (navbar && !(navbar.classList.contains('sticky-top') && navbar.classList.contains('shadow-sm'))) {
            // Check the scroll position
            var scrollPosition = window.scrollY || document.documentElement.scrollTop
      
            // Add the style margin-top: 0 !important; if scrolled
            if (scrollPosition > 0) {
              navbar.style.setProperty('margin-top', '0', 'important')
              // console.log(navbar.style.marginTop);
            } else if (scrollPosition <= 5) {
              // Adjust the threshold value as needed
              console.log('at-top')
              // Reset the style if at the top
              navbar.style.marginTop = ''
            }
          }
        }
      
        // Initial check
        applySecondStylesOnScroll()
      
        // Attach the function to the scroll event
        window.addEventListener('scroll', applySecondStylesOnScroll)
      })
    </script>
